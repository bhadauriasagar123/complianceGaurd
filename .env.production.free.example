# =============================================================================
# FREE PRODUCTION HOSTING (Render API + Vercel UI + Neon DB)
# Copy values into Render/Vercel dashboards — never commit real secrets.
# Full guide: docs/DEPLOY_FREE.md
# =============================================================================

APP_ENV=production
APP_DEBUG=false
APP_URL=https://YOUR-APP.vercel.app
API_URL=https://YOUR-API.onrender.com

SECRET_KEY=generate-with-python-secrets-token-hex-32
FIELD_ENCRYPTION_KEY=generate-with-cryptography-fernet

# Neon PostgreSQL (free): https://neon.tech
# Use "Pooled connection" string, replace postgresql:// with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Redis/Celery — not required when SCAN_MOCK_MODE=true
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

SCAN_MOCK_MODE=true

# Cross-origin cookies (frontend on Vercel, API on Render)
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=

# Comma-separated — include your exact Vercel URL
CORS_ORIGINS=https://YOUR-APP.vercel.app

# Optional — AI remediation (paid API, skip for 100% free)
ANTHROPIC_API_KEY=

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

RATE_LIMIT_PER_MINUTE=60
PROMETHEUS_ENABLED=false
REPORT_STORAGE_PATH=/tmp/reports
