# =============================================================================
# COMPLIANCEGUARD - Environment Configuration
# Copy to .env and fill values. NEVER commit .env to version control.
# =============================================================================

# Application
APP_NAME=ComplianceGuard
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
API_VERSION=v1
SECRET_KEY=change-me-to-64-char-random-string-use-openssl-rand-hex-32

# Database
DATABASE_URL=postgresql+asyncpg://complianceguard:complianceguard@localhost:5432/complianceguard
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT / Auth
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=complianceguard
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=localhost

# Encryption (Fernet key - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=

# MFA
MFA_ISSUER=ComplianceGuard

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@complianceguard.io
SMTP_TLS=true

# Anthropic AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (used when Anthropic key is not set, or as fallback in auto mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# auto | anthropic | openai — auto tries Anthropic first, then OpenAI
AI_PROVIDER=auto
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1

# Scan Security
SCAN_MAX_CONCURRENT=5
SCAN_TIMEOUT_SECONDS=3600
SCAN_RATE_LIMIT_PER_HOUR=10
SCAN_DENY_PRIVATE_IPS=true
SCAN_DENY_LOCALHOST=true
SCAN_DENY_METADATA=true
SCAN_SANDBOX_NETWORK=scan-sandbox

# Scanner Paths (container paths)
NMAP_PATH=/usr/bin/nmap
NUCLEI_PATH=/usr/bin/nuclei
NUCLEI_TEMPLATES_PATH=/opt/nuclei-templates
ZAP_API_URL=http://zap:8080

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# Vault (optional)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_MOUNT=secret

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIMES=application/pdf,image/png,image/jpeg

# Report Generation
REPORT_STORAGE_PATH=/app/reports
REPORT_RETENTION_DAYS=90

# Free online hosting (Render + Neon): set true — no Redis/scanners required
# See docs/DEPLOY_FREE.md
SCAN_MOCK_MODE=false
# Passive HTTP header/cookie checks when mock mode is on (Render free tier)
SCAN_MOCK_HTTP_PROBE=true
